# ─────────────────────────────────────────────────────────────────────────────
# Tallei — environment variable reference
#
# Canonical variable names use the TALLEI_<GROUP>__<KEY> convention.
# Legacy names (e.g. PORT, DATABASE_URL, OPENAI_API_KEY) are still accepted for
# one release via dual-read aliasing in src/config/load.ts, but will be removed
# in the next major version.  Migrate to TALLEI_* names at your earliest
# convenience.
#
# See docs/adr/005-config-schema-zod.md for full rationale.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
TALLEI_HTTP__PORT=3000
# Local dev defaults to 127.0.0.1; use 0.0.0.0 for containers / cloud.
TALLEI_HTTP__HOST=127.0.0.1

# Root public URL exposed to the internet (ngrok, Railway, Fly, etc.).
# Do NOT include /mcp here.
TALLEI_HTTP__PUBLIC_BASE_URL=https://<ngrok-url>
TALLEI_HTTP__FRONTEND_URL=https://<ngrok-url>
TALLEI_HTTP__DASHBOARD_BASE_URL=https://<ngrok-url>

# Public MCP endpoint — proxied through Next.js at /mcp
TALLEI_HTTP__MCP_URL=https://<ngrok-url>/mcp

# Shared secret used for backend ↔ Next.js server-to-server calls.
# Generate with: openssl rand -hex 32
TALLEI_HTTP__INTERNAL_API_SECRET=

# ── Database (Postgres) ───────────────────────────────────────────────────────
TALLEI_DB__URL=postgresql://tallei:tallei@localhost:5432/tallei
TALLEI_DB__URL_FALLBACK=postgresql://tallei:tallei@localhost:5432/tallei
TALLEI_AUTH__SUPABASE_URL=https://<project-ref>.supabase.co
TALLEI_AUTH__SUPABASE_SERVICE_ROLE_KEY=
ENABLE_SUPABASE_RLS_POLICIES=true

# ── Auth / crypto ─────────────────────────────────────────────────────────────
# JWT secret for MCP OAuth tokens (NOT web sessions — those use NextAuth).
TALLEI_AUTH__JWT_SECRET=your_jwt_secret

# Optional: provide an EC keypair to issue ES256 auth continuation tokens.
TALLEI_AUTH__CONTINUATION_PRIVATE_KEY=
TALLEI_AUTH__CONTINUATION_PUBLIC_KEY=
TALLEI_AUTH__CONTINUATION_TTL_SECONDS=600

# 32-byte memory encryption key in hex or base64. Required in production.
TALLEI_AUTH__MEMORY_MASTER_KEY=
TALLEI_AUTH__KMS_KEY_ID=tallei-memory-key-v1

# ── Storage ───────────────────────────────────────────────────────────────────
# Required for raw file blob uploads.
TALLEI_STORAGE__UPLOADTHING_TOKEN=

# ── LLM / generation provider ────────────────────────────────────────────────
# LOCAL_MODEL_MODE=true defaults LLM + embedding to Ollama in non-production.
# Set TALLEI_LLM__LOCAL_MODEL_MODE=false to use OpenAI in local/dev.
TALLEI_LLM__LOCAL_MODEL_MODE=true
TALLEI_LLM__PROVIDER=ollama
TALLEI_LLM__CHAT_MODEL=gpt-4o-mini
TALLEI_LLM__OLLAMA_BASE_URL=http://localhost:11434/v1
TALLEI_LLM__OLLAMA_MODEL=qwen2.5:7b

# Required only when using the OpenAI provider.
TALLEI_LLM__OPENAI_API_KEY=sk-xxx

# ── Embedding ─────────────────────────────────────────────────────────────────
TALLEI_EMBED__PROVIDER=ollama
TALLEI_EMBED__MODEL=nomic-embed-text
# Must match your embedding model's output dimension for Qdrant collection schema.
TALLEI_EMBED__DIMS=768

# ── Qdrant (vector store) ────────────────────────────────────────────────────
TALLEI_QDRANT__URL=https://<cluster-id>.cloud.qdrant.io
TALLEI_QDRANT__API_KEY=
# Use a separate collection for local embeddings to avoid dimension conflicts.
TALLEI_QDRANT__COLLECTION=memories_local_v1

# ── Redis (cache + rate limiting) ────────────────────────────────────────────
TALLEI_REDIS__URL=redis://localhost:6379
TALLEI_REDIS__CONNECT_TIMEOUT_MS=1500
TALLEI_REDIS__COMMAND_TIMEOUT_MS=800
TALLEI_REDIS__FAILURE_COOLDOWN_MS=300000

# ── Rate limits ───────────────────────────────────────────────────────────────
TALLEI_RATE__MCP_PER_MINUTE=240
TALLEI_RATE__MEMORY_API_PER_MINUTE=180

# ── Resilience tunables (leave unset to use env-appropriate defaults) ─────────
# TALLEI_RESILIENCE__VECTOR_UPSERT_TIMEOUT_MS=10000
# TALLEI_RESILIENCE__RECALL_EMBED_TIMEOUT_MS=5000
# TALLEI_RESILIENCE__RECALL_VECTOR_TIMEOUT_MS=8000
# TALLEI_RESILIENCE__RECALL_TOTAL_TIMEOUT_MS=12000

# ── Feature flags ─────────────────────────────────────────────────────────────
TALLEI_FEATURE__GRAPH_EXTRACTION=false
TALLEI_FEATURE__RECALL_V2=false
TALLEI_FEATURE__RECALL_V2_SHADOW=false
TALLEI_FEATURE__DASHBOARD_GRAPH_V2=false
TALLEI_FEATURE__RERANK=true
# Phase 3 use-case cutover flags (ADR-007)
TALLEI_FEATURE__USE_NEW_SAVE=false
TALLEI_FEATURE__USE_NEW_RECALL=false
TALLEI_FEATURE__USE_NEW_LIST=false
TALLEI_FEATURE__USE_NEW_DELETE=false

# ── Misc tunables (leave unset for defaults) ──────────────────────────────────
# TALLEI_MISC__RECALL_MIN_VECTOR_SCORE=0.30
# TALLEI_MISC__RECALL_MIN_FALLBACK_SCORE=0.05
# TALLEI_MISC__RECALL_HYBRID_SIMILARITY_FLOOR=0.35
# TALLEI_MISC__RERANK_MIN_SCORE=0.4
# TALLEI_MISC__MEMORY_FALLBACK_MIN_RELEVANCE=0.2
# TALLEI_MISC__GRAPH_WORKER_POLL_MS=1500
# TALLEI_MISC__GRAPH_WORKER_BATCH_SIZE=16
# TALLEI_MISC__AUTH_USAGE_UPDATE_DEBOUNCE_MS=60000
# TALLEI_MISC__AUTH_USAGE_UPDATE_RETRY_MS=5000
# TALLEI_MISC__AUTH_USAGE_UPDATE_MAX_CONCURRENCY=4

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback for the MCP OAuth flow (proxied via Next.js rewrite /api/* → backend)
GOOGLE_REDIRECT_URI=https://<ngrok-url>/api/auth/google/callback

# ── Billing (LemonSqueezy) ───────────────────────────────────────────────────
TALLEI_BILLING__LEMONSQUEEZY_API_KEY=
TALLEI_BILLING__LEMONSQUEEZY_WEBHOOK_SECRET=
TALLEI_BILLING__LEMONSQUEEZY_PRO_VARIANT_ID=
TALLEI_BILLING__LEMONSQUEEZY_POWER_VARIANT_ID=

# ── Browser automation worker (optional) ─────────────────────────────────────
TALLEI_BROWSER__WORKER_BASE_URL=
TALLEI_BROWSER__WORKER_API_KEY=
TALLEI_BROWSER__WORKER_WS_ENDPOINT=
TALLEI_BROWSER__SESSION_TTL_MS=900000
TALLEI_BROWSER__HEADLESS=true
TALLEI_BROWSER__MAX_RETRIES=2
TALLEI_BROWSER__LLM_FALLBACK=true

CLAUDE_CONNECTOR_MCP_URL=
CLAUDE_PROJECT_INSTRUCTIONS_TEMPLATE=
