# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Local dev default is 127.0.0.1; set HOST=0.0.0.0 for container/cloud runtime.
HOST=127.0.0.1

# Set both to your ngrok frontend root URL (e.g. https://abc123.ngrok-free.app).
# Do not include /mcp in PUBLIC_BASE_URL.
PUBLIC_BASE_URL=https://<ngrok-url>
FRONTEND_URL=https://<ngrok-url>

# Public MCP endpoint — proxied through Next.js at /mcp
# Set to: https://<ngrok-url>/mcp
MCP_URL=https://<ngrok-url>/mcp

# ── Shared secret (backend ↔ Next.js server-to-server) ───────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# ── Postgres (pgvector) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://tallei:tallei@localhost:5432/tallei
DATABASE_URL_FALLBACK=postgresql://tallei:tallei@localhost:5432/tallei
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
ENABLE_SUPABASE_RLS_POLICIES=true

# ── Model providers ───────────────────────────────────────────────────────────
# Local mode defaults to true in non-production and uses Ollama for both LLM + embeddings.
# Set LOCAL_MODEL_MODE=false to default back to OpenAI in local/dev.
LOCAL_MODEL_MODE=true
LLM_PROVIDER=ollama
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
# Must match your embedding model's output dimension for Qdrant collection schema.
EMBEDDING_DIMS=768
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Required only when using OpenAI provider(s).
OPENAI_API_KEY=sk-xxx

# ── Memory encryption (required in production) ───────────────────────────────
# 32-byte key in hex or base64 format
MEMORY_MASTER_KEY=
KMS_KEY_ID=tallei-memory-key-v1

# ── Hosted vector DB (Qdrant Cloud) ──────────────────────────────────────────
QDRANT_URL=https://<cluster-id>.cloud.qdrant.io
QDRANT_API_KEY=
# Use a separate collection for local embeddings to avoid dimension conflicts with production vectors.
QDRANT_COLLECTION_NAME=memories_local_v1

# ── Hosted cache/rate-limit store (Redis) ────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=1500
REDIS_COMMAND_TIMEOUT_MS=800
REDIS_FAILURE_COOLDOWN_MS=300000
AUTH_USAGE_UPDATE_DEBOUNCE_MS=60000
AUTH_USAGE_UPDATE_RETRY_MS=5000
AUTH_USAGE_UPDATE_MAX_CONCURRENCY=4
MEMORY_FALLBACK_MIN_RELEVANCE=0.2
MEMORY_VECTOR_UPSERT_TIMEOUT_MS=10000
MEMORY_RECALL_EMBED_TIMEOUT_MS=5000
MEMORY_RECALL_VECTOR_TIMEOUT_MS=8000
MEMORY_RECALL_TOTAL_TIMEOUT_MS=12000
MCP_RATE_LIMIT_PER_MINUTE=240
MEMORY_API_RATE_LIMIT_PER_MINUTE=180
API_KEY_DB_TIMEOUT_MS=2500
LIST_KEYS_TIMEOUT_MS=2500

# ── Migration controls (dual-write + shadow-read) ────────────────────────────
MEMORY_DUAL_WRITE_ENABLED=false
MEMORY_SHADOW_READ_ENABLED=false

# ── JWT (MCP OAuth tokens — not web sessions, those are NextAuth) ─────────────
JWT_SECRET=your_jwt_secret

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback for the MCP OAuth flow (proxied via Next.js rewrite /api/* → backend)
GOOGLE_REDIRECT_URI=https://<ngrok-url>/api/auth/google/callback

# ── Optional: browser worker ──────────────────────────────────────────────────
BROWSER_WORKER_BASE_URL=
BROWSER_WORKER_API_KEY=
BROWSER_WORKER_WS_ENDPOINT=
BROWSER_SESSION_TTL_MS=900000
BROWSER_HEADLESS=true
BROWSER_MAX_STUDENT_RETRIES=2
BROWSER_LLM_FALLBACK_ENABLED=true
CLAUDE_CONNECTOR_MCP_URL=
CLAUDE_PROJECT_INSTRUCTIONS_TEMPLATE=
