{
  "name": "tallei-ai",
  "version": "0.1.0",
  "description": "Cross-AI persistent memory SaaS",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint --max-warnings=0 \"src/**/*.ts\" \"test/**/*.ts\"",
    "deps:check": "madge --extensions ts --circular src",
    "deps:rules": "depcruise --config .dependency-cruiser.cjs src",
    "test": "npm run test:unit && npm run test:contract && npm run test:integration",
    "test:unit": "tsx --test test/unit/**/*.test.ts",
    "test:contract": "tsx --test test/contract/*.test.ts",
    "test:integration": "tsx --test test/integration/*.test.ts",
    "baseline:metrics": "node scripts/baseline-metrics.mjs",
    "setup:claude": "node scripts/setup-claude-mcp.mjs",
    "setup:chatgpt": "node scripts/setup-chatgpt-actions.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.1",
    "@azure/identity": "^4.13.1",
    "@azure/search-documents": "^12.2.0",
    "@google/genai": "^1.50.1",
    "@langchain/core": "^1.1.40",
    "@mistralai/mistralai": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@supabase/supabase-js": "^2.103.3",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "cloudflare": "^5.2.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "mem0ai": "^2.4.6",
    "multer": "^2.1.1",
    "neo4j-driver": "^6.0.1",
    "ollama": "^0.6.3",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "playwright-core": "^1.55.1",
    "redis": "^5.11.0",
    "uploadthing": "^7.7.4",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.14",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^8.57.1",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "madge": "^8.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
