{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": "./src",
    "paths": {
      "@bootstrap/*": ["bootstrap/*"],
      "@config/*": ["config/*"],
      "@domain/*": ["domain/*"],
      "@infrastructure/*": ["infrastructure/*"],
      "@observability/*": ["observability/*"],
      "@orchestration/*": ["orchestration/*"],
      "@providers/*": ["providers/*"],
      "@resilience/*": ["resilience/*"],
      "@shared/*": ["shared/*"],
      "@transport/*": ["transport/*"]
    },
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
